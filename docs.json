{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenPC Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "anchors": [
      {
        "anchor": "Github",
        "href": "https://github.com/OpenPC-Labs/OpenPC"
      },
      {
        "anchor": "X",
        "href": "https://www.x.com/openpc"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/openpc",
      "github": "https://github.com/OpenPC-Labs/OpenPC",
      "linkedin": "https://linkedin.com/company/mintlify",
      "discord": "https://discord.gg/pNtEGaeR"
    }
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "fonts": {
    "family": "Inter"
  }
}
